# Native Ollama API — embeddings and existing OllamaClient
OLLAMA_BASE_URL=http://localhost:11434

# Pydantic AI — OpenAI-compatible API
PYDANTIC_AI_OLLAMA_BASE_URL=http://localhost:11434/v1

OLLAMA_MODEL=granite4.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

HOST=0.0.0.0
PORT=8000

# Safe workspace verification
# Relative paths are resolved from the backend folder.
VERIFICATION_DB_PATH=data/verification.sqlite3
VERIFICATION_MAX_OUTPUT_CHARS=200000

# Optional: enables Unity batch-mode compile checks.
# Example:
# UNITY_EDITOR_PATH=C:\Program Files\Unity\Hub\Editor\6000.0.0f1\Editor\Unity.exe
UNITY_EDITOR_PATH=
